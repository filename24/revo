generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(ulid())
  fisrname    String
  lastname    String
  birthday    DateTime
  role        Role     @default(STUDENT)
  email       String?
  phoneNumber String

  username String
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  PARENT
  STUDENT
}

model Organization {
  id   String @id @default(ulid())
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
